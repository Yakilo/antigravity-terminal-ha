#!/usr/bin/with-contenv bashio
# ==============================================================================
# Antigravity Terminal - Main Startup Script
# Configures environment and launches Web Console with embedded Raw Terminal
# ==============================================================================

set -euo pipefail

bashio::log.info "Starting Antigravity Terminal..."

# ────────────────────────────────────────────────────────────────────────────
# Read configuration from HA addon options
# ────────────────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=$(bashio::config 'google_api_key')
FONT_SIZE=$(bashio::config 'font_size' '14')
CURSOR_STYLE=$(bashio::config 'cursor_style' 'block')
CURSOR_BLINK=$(bashio::config 'cursor_blink' 'false')

# ────────────────────────────────────────────────────────────────────────────
# Set Environment
# ────────────────────────────────────────────────────────────────────────────
export HOME="/root"
export PATH="/root/.local/bin:/usr/local/bin:${PATH}"
export GOOGLE_API_KEY="${GOOGLE_API_KEY}"
export GEMINI_API_KEY="${GOOGLE_API_KEY}"   # fallback alias
export HASS_HOST="http://supervisor/core"

PERSISTENT_ROOT="/data/agy/root_dir"

# ────────────────────────────────────────────────────────────────────────────
# Restore root directory from persistent data if exists
# ────────────────────────────────────────────────────────────────────────────
if [ -d "${PERSISTENT_ROOT}" ]; then
    bashio::log.info "Restoring persistent home directory..."
    cp -rp ${PERSISTENT_ROOT}/. /root/ 2>/dev/null || true
else
    bashio::log.info "Creating persistent home directory structure..."
    mkdir -p "${PERSISTENT_ROOT}"
fi

# Ensure basic subdirs exist
mkdir -p /root/.config/agy
mkdir -p /root/.local/share/agy
mkdir -p /root/.cache/agy

# Write default config ONLY if not present
# We keep alt-screen as default for the Raw Terminal TUI experience
AGY_CONFIG_DIR="/root/.config/agy"
if [ ! -f "${AGY_CONFIG_DIR}/config.json" ]; then
    bashio::log.info "Initializing default agy configuration..."
    cat > "${AGY_CONFIG_DIR}/config.json" <<EOF
{
  "theme": "dark",
  "renderingMode": "alt-screen",
  "setupComplete": true,
  "autoAcceptedTermsVersion": 1,
  "workspaceTrustConfirmed": true
}
EOF
fi

# ────────────────────────────────────────────────────────────────────────────
# Verify agy is installed, install or update to latest
# ────────────────────────────────────────────────────────────────────────────
if ! command -v agy &>/dev/null; then
    bashio::log.warning "agy not found - installing now..."
    curl -fsSL https://antigravity.google/cli/install.sh | bash \
        && ln -sf /root/.local/bin/agy /usr/local/bin/agy \
        || bashio::log.error "agy installation failed"
else
    # Force update the agy binary on start
    bashio::log.info "Checking/Updating Antigravity CLI..."
    curl -fsSL https://antigravity.google/cli/install.sh | bash &>/dev/null \
        || bashio::log.warning "Could not update agy CLI"
fi

if command -v agy &>/dev/null; then
    bashio::log.info "agy ready: $(agy --version 2>/dev/null || echo 'version ok')"
else
    bashio::log.warning "agy unavailable - terminal will open as bash shell"
fi

# Save state to persistent storage immediately after installation/update
cp -rp /root/. "${PERSISTENT_ROOT}/" 2>/dev/null || true

# ────────────────────────────────────────────────────────────────────────────
# Install extra packages if configured
# ────────────────────────────────────────────────────────────────────────────
if bashio::config.exists 'persistent_apk_packages'; then
    for pkg in $(bashio::config 'persistent_apk_packages[]' 2>/dev/null); do
        bashio::log.info "Installing package: ${pkg}"
        apt-get install -y --no-install-recommends "${pkg}" 2>/dev/null || \
            bashio::log.warning "Failed to install: ${pkg}"
    done
fi

if bashio::config.exists 'persistent_pip_packages'; then
    for pkg in $(bashio::config 'persistent_pip_packages[]' 2>/dev/null); do
        bashio::log.info "Installing pip package: ${pkg}"
        pip3 install --break-system-packages "${pkg}" 2>/dev/null || \
            bashio::log.warning "Failed to install pip package: ${pkg}"
    done
fi

# ────────────────────────────────────────────────────────────────────────────
# Launch background syncer to periodically backup /root/ to /data/
# ────────────────────────────────────────────────────────────────────────────
(
    sleep 15
    while true; do
        cp -rp /root/. "${PERSISTENT_ROOT}/" 2>/dev/null || true
        # Clean up transient tmux files to prevent lock issues on reboot
        rm -rf "${PERSISTENT_ROOT}/.tmux" 2>/dev/null || true
        sleep 10
    done
) &
SYNCER_PID=$!

# ────────────────────────────────────────────────────────────────────────────
# Generate launcher script for ttyd (Raw Terminal)
# Uses tmux for persistence
# ────────────────────────────────────────────────────────────────────────────
cat > /tmp/agy_launch.sh <<SHELL
#!/bin/bash
export PATH="/root/.local/bin:/usr/local/bin:\${PATH}"
export GOOGLE_API_KEY="${GOOGLE_API_KEY}"
export GEMINI_API_KEY="${GOOGLE_API_KEY}"
export HASS_HOST="http://supervisor/core"
export HOME="/root"
export TERM=xterm-256color

cd /config 2>/dev/null || cd /root
SESSION="agy"

if tmux has-session -t "\${SESSION}" 2>/dev/null; then
    exec tmux attach-session -t "\${SESSION}"
else
    exec tmux new-session -s "\${SESSION}" \
        bash -c '
            export HOME="/root"
            export PATH="/root/.local/bin:/usr/local/bin:$PATH"
            export GOOGLE_API_KEY="'"${GOOGLE_API_KEY}"'"
            export GEMINI_API_KEY="'"${GOOGLE_API_KEY}"'"
            export HASS_HOST="http://supervisor/core"
            export TERM=xterm-256color

            if command -v agy &>/dev/null; then
                agy
            else
                echo ""
                echo "  ⚠️  agy not found. Installing..."
                curl -fsSL https://antigravity.google/cli/install.sh | bash
                agy
            fi
            echo ""
            echo "  ─────────────────────────────────────────────"
            echo "  agy exited  │  Type '\''agy'\'' to restart"
            echo "  ─────────────────────────────────────────────"
            exec bash
        '
fi
SHELL
chmod +x /tmp/agy_launch.sh

# ────────────────────────────────────────────────────────────────────────────
# Launch ttyd (Raw Terminal) on Port 8098 (bind to localhost)
# ────────────────────────────────────────────────────────────────────────────
bashio::log.info "Launching ttyd backend on port 8098..."
ttyd \
    --port 8098 \
    --interface 127.0.0.1 \
    --writable \
    --client-option "fontSize=${FONT_SIZE}" \
    --client-option "cursorStyle=${CURSOR_STYLE}" \
    --client-option "cursorBlink=${CURSOR_BLINK}" \
    /tmp/agy_launch.sh &
TTYD_PID=$!

# Trap exit to kill background processes
trap 'kill $SYNCER_PID $TTYD_PID 2>/dev/null || true' EXIT

# ────────────────────────────────────────────────────────────────────────────
# Launch Web Console (Node.js Application) on Port 8099
# ────────────────────────────────────────────────────────────────────────────
bashio::log.info "Launching Web Console Server on port 8099..."
export PORT=8099
exec node /app/server.js
